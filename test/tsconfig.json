{
  "compilerOptions": {
    /* Base Options: */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,

    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,

    /* If NOT transpiling with ts-node: */
    "module": "CommonJS",
    "outDir": "dist",

    /* If your project includes a common directory like `src` */
    "rootDir": "src"
  },
  "include": ["src/**/*"]
}